# ─────────────────────────────────────────────────────────────────────────────
# findata-dq-engine — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Anthropic — Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Modèles Claude configurables ────────────────────────────────────────────
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_BATCH_MODEL=claude-haiku-4-5-20251001
MAX_LLM_REMEDIATION_BATCH=50

# ─── Environnement du pipeline ────────────────────────────────────────────────
# Valeurs possibles : development | staging | production
# En development/staging : la dimension Privacy bloque les PII non masquées
PIPELINE_ENV=development

# ─── Chemins des données ──────────────────────────────────────────────────────
DATA_RAW_PATH=data/raw/
DATA_STAGED_PATH=data/staged/
DATA_MASTERED_PATH=data/mastered/
EXPORT_PATH=outputs/

# ─── Seuils DQ — Timeliness ──────────────────────────────────────────────────
TIMELINESS_V_DAYS=30
TIMELINESS_S_DAYS=90

# ─── Seuils DQ — Congruence (Z-Score) ────────────────────────────────────────
ZSCORE_V_THRESHOLD=2.0
ZSCORE_S_THRESHOLD=3.5
ZSCORE_IV_THRESHOLD=3.5

# ─── Seuils DQ — ModelDrift (PSI) ────────────────────────────────────────────
PSI_S_THRESHOLD=0.10
PSI_IV_THRESHOLD=0.25

# ─── Seuils DQ — Fairness ────────────────────────────────────────────────────
FAIRNESS_DI_V_MIN=0.80
FAIRNESS_DI_V_MAX=1.25
FAIRNESS_DI_S_MIN=0.70
FAIRNESS_DI_IV_THRESHOLD=0.70

# ─── Isolation Forest ─────────────────────────────────────────────────────────
ISOLATION_FOREST_CONTAMINATION=0.05
ISOLATION_FOREST_N_ESTIMATORS=200

# ─── Rétention des données (Loi 25 / RGPD) ───────────────────────────────────
RETENTION_POLICIES_DAYS=2555
RETENTION_CLAIMS_DAYS=3650
RETENTION_LOGS_DAYS=365
RETENTION_MODEL_METADATA_DAYS=1825

# ─── Alerting (optionnel) ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
REPORT_EMAIL_RECIPIENTS=
