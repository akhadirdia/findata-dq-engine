# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ─── Environnements virtuels ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Données (jamais commiter des données réelles) ────────────────────────────
data/raw/
data/staged/
data/mastered/
outputs/
!data/raw/.gitkeep
!data/staged/.gitkeep
!data/mastered/.gitkeep
!outputs/.gitkeep
notes.docx
~$notes.docx
CLAUDE.md

# ─── Fixtures de test (garder dans git) ──────────────────────────────────────
!tests/fixtures/*.csv
!tests/fixtures/*.json

# ─── Coverage & Tests ─────────────────────────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Notebooks ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Docker ───────────────────────────────────────────────────────────────────
*.log

# ─── Modèles ML sérialisés (trop lourds pour git) ────────────────────────────
*.pkl
*.joblib
*.h5
*.pt
*.pth
